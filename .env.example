# Discord Bot Configuration
DISCORD_TOKEN=your_discord_bot_token_here
GUILD_ID=your_discord_server_id_here
COMMAND_PREFIX=!

# Rust+ Server Configuration
# You can use a tool like RustPlus.py Companion to get these credentials
RUST_SERVER_IP=127.0.0.1
RUST_SERVER_PORT=28082
RUST_PLAYER_STEAM_ID=your_64bit_steam_id_here
RUST_PLAYER_TOKEN=your_rustplus_player_token_here

# Channel IDs
EVENTS_CHANNEL_ID=
SMART_ALARM_CHANNEL_ID=
TEAM_CHAT_CHANNEL_ID=
SERVER_INFO_CHANNEL_ID=

# External Advantage APIs
BATTLEMETRICS_TOKEN=your_battlemetrics_token_here
STEAM_API_KEY=your_steam_api_key_here
BATTLEMETRICS_SERVER_ID=your_rust_server_battlemetrics_id

# Phone Alert System
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=your_twilio_phone_number
